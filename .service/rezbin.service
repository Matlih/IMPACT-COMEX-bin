[Unit]
Description=Rezbin OpenCV Sorting App
After=network.target pigpiod.service
Wants=pigpiod.service

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=%h/Project-IMPACT
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/Project-IMPACT/.venv/bin/python %h/Project-IMPACT/main.py --headless
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
